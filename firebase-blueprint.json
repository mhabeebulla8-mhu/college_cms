{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a student or admin in the system.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Full name of the user" },
        "email": { "type": "string", "format": "email", "description": "Email address of the user" },
        "role": { "type": "string", "enum": ["student", "admin"], "description": "Role of the user" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user was created" }
      },
      "required": ["name", "email", "role"]
    },
    "Complaint": {
      "title": "Complaint",
      "description": "A complaint submitted by a student.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "ID of the student who submitted the complaint" },
        "studentName": { "type": "string", "description": "Name of the student for easier display" },
        "category": { 
          "type": "string", 
          "enum": ["Sexual Cell", "Anti-Ragging Cell", "Anti-Harassment Cell", "Grievance Cell", "Hygiene/Facility Cell", "Disciplinary Committee"],
          "description": "The committee the complaint is directed to" 
        },
        "description": { "type": "string", "description": "Detailed description of the complaint" },
        "filePath": { "type": "string", "description": "Path to the uploaded file in storage" },
        "status": { "type": "string", "enum": ["Pending", "In Progress", "Resolved"], "description": "Current status of the complaint" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp of submission" }
      },
      "required": ["userId", "category", "description", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/complaints/{complaintId}": {
      "schema": "Complaint",
      "description": "Collection of all student complaints"
    }
  }
}
